{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "IntentSpecification",
  "type": "object",
  "required": ["userConstraints"],
  "properties": {
    "query": {
      "type": "object",
      "properties": {
        "chemical": {
          "type": "object",
          "properties": {
            "category": {
              "type": "string",
              "enum": [
                "structure",
                "molecule"
              ],
              "description": "The type of molecule that is being simulated in Pymatgen"
            },
            "atoms": {
              "type": "array",
              "description": "Array of objects containing elements and locations data for each atom",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "species",
                  "coordinates"
                ],
                "properties": {
                  "species": {
                    "type": "string",
                    "description": "The element of an atom"
                  },
                  "coordinates": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "description": "the coordinate locations for individual atoms",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "lattice": {
              "type": "array",
              "description": "The array for the repetition of a given structure. MUST be a three by three matrix",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "number"
                }
              }
            },
            "experiment": {
              "type": "object",
              "description": "What experiment we are running",
              "properties": {
                "method": {
                  "type": "string",
                  "enum" : ["MPRelaxSet", "MPStaticSet", "MPNonSCFSet"],
                  "description": "General function for different experiment types"
                },
                "kpointOverride": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "description": "parameter value pairs for overriding settings",
                    "properties": {
                      "overrideParameter": {
                        "type": "string",
                        "description": "The actual parameter being overwritten"
                      },
                      "overrideValue": {
                        "type": "string",
                        "description": "The value for the overwritten parameter"
                      }
                    }
                  }
                },
                "incarOverride": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "description": "parameter value pairs for overriding settings",
                    "properties": {
                      "overrideParameter": {
                        "type": "string",
                        "description": "The actual parameter being overwritten"
                      },
                      "overrideValue": {
                        "type": "string",
                        "description": "The value for the overwritten parameter"
                      }
                    }
                  }
                },
                "potcarOverride": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "description": "parameter value pairs for overriding settings",
                    "properties": {
                      "overrideParameter": {
                        "type": "string",
                        "description": "The actual parameter being overwritten"
                      },
                      "overrideValue": {
                        "type": "string",
                        "description": "The value for the overwritten parameter"
                      }
                    }
                  }
                }
              }

            }
          }
        },
        "ase": {
          "type": "object",
          "description": "ASE (Atomic Simulation Environment) specification. Kept separate from the Pymatgen `chemical` block so both engines can be run and benchmarked against each other.",
          "properties": {
            "structure": {
              "type": "object",
              "description": "Mirrors an ASE Atoms object: elements, positions, cell, and periodicity",
              "properties": {
                "category": {
                  "type": "string",
                  "enum": ["structure", "molecule"],
                  "description": "structure -> periodic Atoms with a cell; molecule -> non-periodic Atoms"
                },
                "coordinateSystem": {
                  "type": "string",
                  "enum": ["cartesian", "fractional"],
                  "default": "cartesian",
                  "description": "cartesian -> ASE positions; fractional -> ASE scaled_positions"
                },
                "pbc": {
                  "description": "Periodic boundary conditions. Either one boolean applied to all axes, or three booleans for [a, b, c].",
                  "oneOf": [
                    { "type": "boolean" },
                    {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "items": { "type": "boolean" }
                    }
                  ]
                },
                "atoms": {
                  "type": "array",
                  "description": "List of atoms; each has an element symbol and a 3D coordinate",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["species", "coordinates"],
                    "properties": {
                      "species": {
                        "type": "string",
                        "description": "Chemical symbol of the atom, e.g. \"Fe\""
                      },
                      "coordinates": {
                        "type": "array",
                        "minItems": 3,
                        "maxItems": 3,
                        "description": "Position of the atom; interpreted as cartesian or fractional per coordinateSystem",
                        "items": { "type": "number" }
                      }
                    }
                  }
                },
                "cell": {
                  "type": "array",
                  "description": "ASE cell as a 3x3 matrix of lattice vectors. Required for periodic structures.",
                  "minItems": 3,
                  "maxItems": 3,
                  "items": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "items": { "type": "number" }
                  }
                }
              }
            },
            "calculation": {
              "type": "object",
              "required": ["calculator", "calculationType"],
              "description": "What to compute on the structure",
              "properties": {
                "calculator": {
                  "type": "string",
                  "enum": ["emt", "vasp", "gpaw", "espresso", "lammps"],
                  "description": "ASE calculator that provides energies and forces"
                },
                "calculationType": {
                  "type": "string",
                  "enum": ["static", "relax", "md", "neb", "eos", "vibrations"],
                  "description": "Type of ASE calculation to perform"
                },
                "relax": {
                  "type": "object",
                  "description": "Parameters for a structure optimization (calculationType = relax)",
                  "properties": {
                    "optimizer": {
                      "type": "string",
                      "enum": ["BFGS", "LBFGS", "FIRE", "GPMin", "MDMin"],
                      "default": "BFGS",
                      "description": "ASE optimizer algorithm"
                    },
                    "fmax": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "description": "Force convergence criterion in eV/Angstrom. Default: 0.05"
                    },
                    "maxSteps": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Maximum number of optimizer steps"
                    }
                  }
                },
                "md": {
                  "type": "object",
                  "description": "Parameters for molecular dynamics (calculationType = md)",
                  "properties": {
                    "ensemble": {
                      "type": "string",
                      "enum": ["NVE", "NVT", "NPT"],
                      "description": "Thermodynamic ensemble"
                    },
                    "timeStep": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "description": "Integration time step in femtoseconds"
                    },
                    "steps": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Number of MD steps"
                    },
                    "temperature": {
                      "type": "number",
                      "minimum": 0,
                      "description": "Target temperature in Kelvin (required for NVT/NPT)"
                    }
                  }
                },
                "neb": {
                  "type": "object",
                  "description": "Parameters for a Nudged Elastic Band calculation (calculationType = neb)",
                  "properties": {
                    "images": {
                      "type": "integer",
                      "minimum": 3,
                      "description": "Number of images along the band, including the two endpoints"
                    },
                    "fmax": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "description": "Force convergence criterion in eV/Angstrom"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "userConstraints": {
      "type": "object",
      "required": ["metadata"],
      "properties": {
        "metadata": {
          "type": "object",
          "required": ["submissionId", "inputType", "timeStamp"],
          "properties": {
            "user": {
              "type": "string",
              "description": "The user who submitted the request"
            },

            "submissionId": {
              "type": "string",
              "description": "A unique id to identify the request"
            },

            "inputType": {
              "type": "string",
              "enum": ["chemistry", "physics", "biophysics", "materials"],
              "description": "The type of simulation the query will be performing"
            },

            "timeStamp": {
              "type": "string",
              "format": "date-time",
              "description": "The time the query was submitted"
            }
          }
        },

        "slurmInfo": {
          "type": "object",
          "description": "Container for the slurm data. Can be specified by the user but not required",
          "properties": {
            "cpuCount": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of CPUs requested, minimum of 1. Default: 8"
            },

            "gpuCount": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of GPUs requested, minimum of 0. Default: 0"
            },

            "ramAmount": {
              "type": "integer",
              "description": "Amount of RAM requested, MEASURED IN MEGABYTES ONLY. Default: 4000MB"
            },

            "maxTime": {
              "type": "integer",
              "minimum": 1,
              "description": "The maximum number of hours the query is allowed to run before shutting down. Default: 8 hours"
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "userConstraints": {
            "properties": {
              "metadata": {
                "properties": {
                  "inputType": { "const": "chemistry" }
                }
              }
            }
          }
        }
      },
      "then": {
        "required": ["query"],
        "properties": {
          "query": {
            "required": ["chemical"],
            "properties": {
              "chemical": {
                "required": ["category", "atoms", "experiment"],
                "properties": {
                  "experiment": {
                    "required": ["method"]
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["query"],
        "properties": {
          "query": {
            "required": ["chemical"],
            "properties": {
              "chemical": {
                "required": ["category"],
                "properties": {
                  "category": { "const": "structure" }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "query": {
            "properties": {
              "chemical": {
                "required": ["lattice"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query": {
            "properties": {
              "ase": {
                "properties": {
                  "structure": {
                    "properties": {
                      "category": { "const": "structure" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "query": {
            "properties": {
              "ase": {
                "properties": {
                  "structure": {
                    "required": ["cell"]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
