{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "IntentSpecification",
  "type": "object",
  "required": ["userConstraints"],
  "properties": {
    "query": {
      "type": "object",
      "properties": {
        "chemical": {
          "type": "object",
          "properties": {
            "category": {
              "type": "string",
              "enum": [
                "structure",
                "molecule"
              ],
              "description": "The type of molecule that is being simulated in Pymatgen"
            },
            "atoms": {
              "type": "array",
              "description": "Array of objects containing elements and locations data for each atom",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "species",
                  "coordinates"
                ],
                "properties": {
                  "species": {
                    "type": "string",
                    "description": "The element of an atom"
                  },
                  "coordinates": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "description": "the coordinate locations for individual atoms",
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "lattice": {
              "type": "array",
              "description": "The array for the repetition of a given structure. MUST be a three by three matrix",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "userConstraints": {
      "type": "object",
      "required": ["metadata"],
      "properties": {
        "metadata": {
          "type": "object",
          "required": ["submissionId", "inputType", "timeStamp"],
          "properties": {
            "user": {
              "type": "string",
              "description": "The user who submitted the request"
            },

            "submissionId": {
              "type": "string",
              "description": "A unique id to identify the request"
            },

            "inputType": {
              "type": "string",
              "enum": ["chemistry", "physics", "biophysics", "materials"],
              "description": "The type of simulation the query will be performing"
            },

            "timeStamp": {
              "type": "string",
              "format": "date-time",
              "description": "The time the query was submitted"
            }
          }
        },

        "slurmInfo": {
          "type": "object",
          "description": "Container for the slurm data. Can be specified by the user but not required",
          "properties": {
            "cpuCount": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of CPUs requested, minimum of 1. Default: 8"
            },

            "gpuCount": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of GPUs requested, minimum of 0. Default: 0"
            },

            "ramAmount": {
              "type": "integer",
              "description": "Amount of RAM requested, MEASURED IN MEGABYTES ONLY. Default: 4000MB"
            },

            "maxTime": {
              "type": "integer",
              "minimum": 1,
              "description": "The maximum number of hours the query is allowed to run before shutting down. Default: 8 hours"
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "userConstraints": {
            "properties": {
              "metadata": {
                "properties": {
                  "inputType": { "const": "chemistry" }
                }
              }
            }
          }
        }
      },
      "then": {
        "required": ["query"],
        "properties": {
          "query": {
            "required": ["chemical"],
            "properties": {
              "chemical": {
                "required": ["category", "atoms"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query": {
            "properties": {
              "chemical": {
                "properties": {
                  "category": { "const": "structure" }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "query": {
            "properties": {
              "chemical": {
                "required": ["lattice"]
              }
            }
          }
        }
      }
    }
  ]
}
